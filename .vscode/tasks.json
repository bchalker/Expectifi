{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start: client + server (on folder open)",
      "dependsOrder": "parallel",
      "dependsOn": ["Dev: client (Vite)", "Dev: server (Express)"],
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Dev: client (Vite)",
      "type": "shell",
      "command": "npm run dev -w client",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "Dev: server (Express)",
      "type": "shell",
      "command": "npm run dev -w server",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    }
  ]
}
