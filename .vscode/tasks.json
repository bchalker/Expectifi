{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "deployCommitMessage",
      "type": "promptString",
      "description": "Commit message (required when you have uncommitted changes)",
      "default": "Deploy production updates"
    }
  ],
  "tasks": [
    {
      "label": "Start: client + server (on folder open)",
      "dependsOrder": "parallel",
      "dependsOn": ["Dev: client (Vite)", "Dev: server (Express)"],
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Dev: client (Vite)",
      "type": "shell",
      "command": "npm run dev -w client",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "Dev: server (Express)",
      "type": "shell",
      "command": "npm run dev -w server",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "Deploy: commit, build check, push to Railway",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/deploy-railway.sh",
        "${input:deployCommitMessage}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": true,
        "echo": true,
        "showReuseMessage": false
      }
    },
    {
      "label": "Deploy: push only (already committed)",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/scripts/deploy-railway.sh", "--push-only"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": true,
        "echo": true,
        "showReuseMessage": false
      }
    }
  ]
}
