# Copy to ~/.retirement-calc-dev.env (home folder, not the repo) and uncomment.
# launch-local-dev.sh sources that file automatically.

# SSH Host alias from ~/.ssh/config (User, Port, IdentityFile live there)
# DEV_SSH_CONFIG_HOST=retirement-calc-db

# DEV_LOCAL_DB_PORT=3307

# Optional: repo path if not ~/retirement-calculator
# RETIREMENT_CALC_HOME=/Users/you/retirement-calculator

# Optional: longer pause before API if tunnel is slow (seconds)
# DEV_SSH_TUNNEL_SLEEP=3
