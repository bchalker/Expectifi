# Server (`server/.env` or repo root — dotenv loads cwd)
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# MySQL: either a URL or discrete vars
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/retirement_calculator
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=retirement_calculator

# JWT for session cookie — use a long random string (32+ chars)
JWT_SECRET=change-me-to-a-long-random-secret-string

# Teller.io (optional)
TELLER_APPLICATION_ID=
TELLER_ENV=sandbox
