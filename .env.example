# =============================================================================
# Copy values into server/.env (on your Mac for dev, on the VPS for production).
# Never commit server/.env — it is gitignored.
# =============================================================================

PORT=3001

# Browser origin for this environment (CORS + cookies).
# Local dev:
CLIENT_ORIGIN=http://localhost:5173
# Production (VPS only):
# CLIENT_ORIGIN=https://eggspectifi.com

# -----------------------------------------------------------------------------
# MySQL — production (VPS): leave USE_STAGING_DB unset; use MYSQL_* only.
#
# Local Mac with a separate staging DB: set USE_STAGING_DB=true and use
# staging_MYSQL_* (or STAGING_MYSQL_*). If a staging_* value is missing,
# the server falls back to plain MYSQL_* for that field.
# -----------------------------------------------------------------------------

# USE_STAGING_DB=true

# staging_MYSQL_HOST=127.0.0.1
# staging_MYSQL_PORT=3307
# staging_MYSQL_USER=your_staging_user
# staging_MYSQL_PASSWORD=your_staging_password
# staging_MYSQL_DATABASE=your_staging_database

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_staging_user
MYSQL_PASSWORD=your_staging_password
MYSQL_DATABASE=your_staging_database

# Or a single URL (overrides discrete vars if your tooling supports it):
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/your_staging_database

# ---
# Connect FROM YOUR MAC to MySQL that only listens on the VPS (common):
#
#   ssh -p 2200 -L 3307:127.0.0.1:3306 root@YOUR_VPS_IP
#
# Leave that terminal open. Then in server/.env on the Mac:
#
#   MYSQL_HOST=127.0.0.1
#   MYSQL_PORT=3307
#   MYSQL_USER=eggspectifi_staging   (example)
#   MYSQL_PASSWORD=...
#   MYSQL_DATABASE=eggspectifi_staging
#
# The API and `npm run dev -w server` on your Mac then use the tunneled DB.
# ---

# Alternative: run MySQL only on your Mac (Docker/Homebrew) and point MYSQL_*
# at localhost with a local database name — nothing on the VPS.

# JWT — at least 32 random characters. Use a different value per environment.
JWT_SECRET=change-me-to-a-long-random-secret-string

# Teller.io (optional)
TELLER_APPLICATION_ID=
TELLER_ENV=sandbox
