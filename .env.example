# =============================================================================
# Copy values into server/.env (on your Mac for dev, on Railway/VPS for production).
# Never commit server/.env — it is gitignored.
# =============================================================================

PORT=3001

# Browser origin for this environment (CORS + cookies).
# Local dev:
CLIENT_ORIGIN=http://localhost:5173
# Production:
# CLIENT_ORIGIN=https://expectifi.com

# -----------------------------------------------------------------------------
# PostgreSQL — production: use DATABASE_URL or PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE
#
# Local staging: USE_STAGING_DB=true and staging_DATABASE_URL (or staging_PG*).
# If a staging_* value is missing, the server falls back to plain PG* / DATABASE_URL.
# -----------------------------------------------------------------------------

# USE_STAGING_DB=true
# staging_DATABASE_URL=postgresql://user:password@127.0.0.1:5433/staging_db

DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/retirement_calculator

# Or discrete vars (used when DATABASE_URL is unset):
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=
# PGDATABASE=retirement_calculator

# Public API URL (Google OAuth redirect base). No trailing slash.
# API_PUBLIC_URL=http://localhost:3001

# JWT — at least 32 random characters. Use a different value per environment.
JWT_SECRET=change-me-to-a-long-random-secret-string

# Stripe — server only (see client/.env.example for VITE_STRIPE_PUBLISHABLE_KEY)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_SUBSCRIPTION_PRICE_ID=price_...

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Teller.io (optional)
TELLER_APPLICATION_ID=
TELLER_ENV=sandbox
