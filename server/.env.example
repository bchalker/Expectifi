# Copy to server/.env (gitignored). Never commit real secrets.

# Required for JWT session cookies
JWT_SECRET=change-me-to-a-long-random-string

# PostgreSQL — prefer DATABASE_URL (Railway sets this when you link Postgres)
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/retirement_calculator

PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=retirement_calculator

# Browser origin (Vite dev default)
CLIENT_ORIGIN=http://localhost:5173

# Public URL of this API (no trailing slash). Google OAuth redirect base.
# Local dev redirect URI in Google Cloud Console:
#   http://localhost:3001/api/auth/google/callback
API_PUBLIC_URL=http://localhost:3001

# Google Sign-In (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe — required for paid signups ($9/mo subscription)
# STRIPE_SECRET_KEY=sk_test_...
# Recurring price: Dashboard → Product catalog → add product → $9/month → copy price_… id
# STRIPE_SUBSCRIPTION_PRICE_ID=price_...
# Webhook signing secret (Dashboard → Developers → Webhooks → endpoint → Signing secret)
# Local: stripe listen --forward-to localhost:3001/api/stripe/webhook
# STRIPE_WEBHOOK_SECRET=whsec_...
# Events: customer.subscription.updated, customer.subscription.deleted,
#         invoice.paid, invoice.payment_failed

# Plaid — investments / account linking (optional)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# Local dev with staging DB: USE_STAGING_DB=true and staging_DATABASE_URL or staging_PG*
