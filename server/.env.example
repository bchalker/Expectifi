# Copy to server/.env (gitignored). Never commit real secrets.

# Required for JWT session cookies
JWT_SECRET=change-me-to-a-long-random-string

# PostgreSQL — prefer DATABASE_URL (Railway sets this when you link Postgres)
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/retirement_calculator

PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=retirement_calculator

# Browser origin (Vite dev default)
CLIENT_ORIGIN=http://localhost:5173

# Public URL of this API (no trailing slash). Google OAuth redirect base.
# Local dev redirect URI in Google Cloud Console:
#   http://localhost:3001/api/auth/google/callback
API_PUBLIC_URL=http://localhost:3001

# Google Sign-In (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe — required for paid signups ($9/mo subscription)
# STRIPE_SECRET_KEY=sk_test_...
# Recurring price: Dashboard → Product catalog → add product → $9/month → copy price_… id
# STRIPE_SUBSCRIPTION_PRICE_ID=price_...
# Webhook signing secret (Dashboard → Developers → Webhooks → endpoint → Signing secret)
# Local: stripe listen --forward-to localhost:3001/api/stripe/webhook
# STRIPE_WEBHOOK_SECRET=whsec_...
# Events: customer.subscription.updated, customer.subscription.deleted,
#         invoice.paid, invoice.payment_failed
# Friends promo: must exist in the SAME mode as STRIPE_SECRET_KEY (test vs live).
# Local sk_test_ → Stripe Dashboard with "Test mode" ON → Coupon 100% Forever → code expectifi2026
# Or run: npm run seed:test-promo -w server

# Contact form: SMTP delivery (CONTACT_TO avoids Gmail dedup when SMTP_USER is the same inbox)
# CONTACT_TO=bchalker+expectifi@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Expectifi <noreply@expectifi.com>

# Plaid — investments / account linking (optional)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# TrueLayer — open banking (optional; https://console.truelayer.com)
# Local dev: toggle Live OFF in Console, use Sandbox client_id (sandbox-… prefix).
# Sandbox auth host is auth.truelayer-sandbox.com — set TRUELAYER_ENV=sandbox (required).
# Register TRUELAYER_REDIRECT_URI in the same Console environment (must match exactly).
# TRUELAYER_CLIENT_ID=sandbox-yourapp-…
# TRUELAYER_CLIENT_SECRET=
# Optional override. By default the app sends window.location.origin (e.g. :5174 if 5173 is busy).
# Whitelist every localhost port you use in TrueLayer Console, or set this explicitly.
# TRUELAYER_REDIRECT_URI=http://localhost:5173/api/truelayer/callback
# TRUELAYER_ENV=sandbox
# Sandbox uses Mock Bank (uk-cs-mock) — real ES/DE banks need live credentials.

# Local dev with staging DB: USE_STAGING_DB=true and staging_DATABASE_URL or staging_PG*
