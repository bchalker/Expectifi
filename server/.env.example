# Copy to server/.env (gitignored). Never commit real secrets.

# Required for JWT session cookies
JWT_SECRET=change-me-to-a-long-random-string

# MySQL (or use DATABASE_URL)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=retirement_calculator

# Browser origin (Vite default)
CLIENT_ORIGIN=http://localhost:5173

# Public URL of this API (no trailing slash). Used as Google OAuth redirect base.
# Local dev: add this exact redirect URI in Google Cloud Console → Authorized redirect URIs:
#   http://localhost:3001/api/auth/google/callback
API_PUBLIC_URL=http://localhost:3001

# Google Sign-In (OAuth 2.0). Optional — omit to hide “Continue with Google” in the app.
# Create credentials: Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (optional — required for card-at-signup and for completing Google sign-up)
# When set, new Google users (and Google users without a saved customer) must add a card before rc_session is issued.
# STRIPE_SECRET_KEY=sk_test_...
