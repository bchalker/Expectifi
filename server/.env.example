# Copy to server/.env (gitignored). Never commit real secrets.

# Required for JWT session cookies
JWT_SECRET=change-me-to-a-long-random-string

# PostgreSQL — prefer DATABASE_URL (Railway sets this when you link Postgres)
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/retirement_calculator

PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=retirement_calculator

# Browser origin (Vite dev default). Comma-separate for desktop + phone LAN testing:
# CLIENT_ORIGIN=http://localhost:5173,http://192.168.1.42:5173
CLIENT_ORIGIN=http://localhost:5173

# Public URL of this API (no trailing slash).
API_PUBLIC_URL=http://localhost:3001

# Google Sign-In (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OAuth redirect URI — must match Google Cloud Console → Authorized redirect URIs exactly.
# Path is always /api/auth/google/callback (not /auth/google/callback).
#
# Desktop local dev (pick the port Vite prints — 5173, 5174, etc.):
# GOOGLE_CALLBACK_URL=http://localhost:5174/api/auth/google/callback
# Also add that exact URL in Google Cloud Console.
#
# Phone testing: Google rejects private IPs (192.168.x.x). localhost on your phone
# is the phone itself, not your Mac — so LAN IP + localhost OAuth will not work.
# Use a tunnel (ngrok, Cloudflare Tunnel) or test on staging/production instead:
#   ngrok http 5174
#   CLIENT_ORIGIN=https://YOUR-SUBDOMAIN.ngrok-free.app
#   GOOGLE_CALLBACK_URL=https://YOUR-SUBDOMAIN.ngrok-free.app/api/auth/google/callback
# Add the https://…/api/auth/google/callback URL in Google Cloud Console.

# Stripe — required for paid signups ($9/mo subscription)
# STRIPE_SECRET_KEY=sk_test_...
# Recurring price: Dashboard → Product catalog → add product → $9/month → copy price_… id
# STRIPE_SUBSCRIPTION_PRICE_ID=price_...
# Webhook signing secret (Dashboard → Developers → Webhooks → endpoint → Signing secret)
# Local: stripe listen --forward-to localhost:3001/api/stripe/webhook
# STRIPE_WEBHOOK_SECRET=whsec_...
# Events: customer.subscription.updated, customer.subscription.deleted,
#         invoice.paid, invoice.payment_failed
# Friends promo: must exist in the SAME mode as STRIPE_SECRET_KEY (test vs live).
# Local sk_test_ → Stripe Dashboard with "Test mode" ON → Coupon 100% Forever → code expectifi2026
# Or run: npm run seed:test-promo -w server

# Contact form: SMTP delivery (CONTACT_TO avoids Gmail dedup when SMTP_USER is the same inbox)
# CONTACT_TO=bchalker+expectifi@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Expectifi <noreply@expectifi.com>

# Plaid — investments / account linking (optional)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# Local dev with staging DB: USE_STAGING_DB=true and staging_DATABASE_URL or staging_PG*
